# Dashboard env — copy to .env.local
# Django RAPIDA backend base (server-side proxy routes use this)
RAPIDA_API_BASE=http://localhost:8000/api

# Faraja AI co-pilot (browser-side — must be reachable from the user's browser).
# The AiAssistant calls ${NEXT_PUBLIC_FARAJA_API_URL}/copilot directly.
NEXT_PUBLIC_FARAJA_API_URL=http://localhost:8088
