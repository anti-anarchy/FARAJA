# Top-level env for docker-compose. Copy to .env.
# Both AI keys are free (no card):
#   Primary engine → https://aistudio.google.com/apikey
#   Backup engine  → https://console.groq.com/keys

LLM_PROVIDERS=gemini,groq
GEMINI_API_KEY=
GROQ_API_KEY=

# Django RAPIDA backend base, shared by dashboard + responders-app.
RAPIDA_API_BASE=http://host.docker.internal:8000/api

# Optional: lock Faraja CORS to your app origins in production.
FARAJA_CORS_ORIGINS=*
