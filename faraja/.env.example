# Faraja AI service — copy to .env and fill in. Both keys are free, no card:
#   Primary engine key → https://aistudio.google.com/apikey
#   Backup engine key  → https://console.groq.com/keys

LLM_PROVIDERS=gemini,groq
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

APP_PORT=8088
APP_ENV=development
# In production, lock this down to your app origins:
CORS_ORIGINS=*
